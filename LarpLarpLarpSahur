local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function rgb(c) return Color3.fromRGB(c.R, c.G, c.B) end
local function udim2(xs, xo, ys, yo) return UDim2.new(xs, xo, ys, yo) end
local function udim(scale, offset) return UDim.new(scale, offset) end

local function getUIParent()
    local success, parent = pcall(gethui)
    if success and parent then return parent end
    success, parent = pcall(function() return game:GetService("CoreGui") end)
    if success and parent then return parent end
    return LocalPlayer:WaitForChild("PlayerGui")
end

local function Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do inst[k] = v end
    return inst
end

local function Tween(obj, props, time)
    local t = TweenService:Create(obj, TweenInfo.new(time or Config.Animations.Speed, Config.Animations.EasingStyle, Config.Animations.EasingDirection), props)
    t:Play()
    return t
end

local NotificationContainer = nil
local function SetupNotifications()
    local parent = getUIParent()
    if parent:FindFirstChild("NebulaNotifs") then parent.NebulaNotifs:Destroy() end
    local screen = Create("ScreenGui", { Parent = parent, Name = "NebulaNotifs", ResetOnSpawn = false })
    local container = Create("Frame", { Parent = screen, Size = udim2(1, -20, 1, -20), Position = udim2(0, 10, 0, 10), BackgroundTransparency = 1 })
    Create("UIListLayout", { Parent = container, Padding = udim(0, 8), VerticalAlignment = Enum.VerticalAlignment.Bottom, HorizontalAlignment = Enum.HorizontalAlignment.Right })
    NotificationContainer = container
end

local function Notify(props)
    if not NotificationContainer then SetupNotifications() end
    local notif = Create("Frame", {
        Parent = NotificationContainer,
        Size = udim2(0, 280, 0, 40),
        BackgroundColor3 = rgb(Config.Colors.Element),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
    })
    Create("UICorner", { Parent = notif, CornerRadius = udim(0, Config.Borders.ElementRadius) })
    Create("UIStroke", { Parent = notif, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    local text = Create("TextLabel", {
        Parent = notif,
        Size = udim2(1, -20, 1, 0),
        Position = udim2(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = props.Text or "Notification",
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.LabelSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    Tween(notif, { BackgroundTransparency = 0, Position = udim2(0, 0, 1, -50) }, 0.3)
    task.delay(props.Duration or 3, function()
        Tween(notif, { BackgroundTransparency = 1 }, 0.3)
        task.wait(0.3)
        notif:Destroy()
    end)
end

local ElementBuilder = {}

function ElementBuilder:Label(p)
    return Create("TextLabel", {
        Parent = p.Parent,
        Size = udim2(1, 0, 0, Config.Sizes.ButtonHeight),
        BackgroundTransparency = 1,
        Text = "  " .. (p.Text or p.Name or "Label"),
        TextColor3 = rgb(Config.Colors[p.Color or "Muted"]),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.LabelSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
end

function ElementBuilder:Button(p)
    local btn = Create("TextButton", {
        Parent = p.Parent,
        Size = udim2(1, 0, 0, Config.Sizes.ButtonHeight),
        BackgroundColor3 = rgb(Config.Colors.Element),
        Text = "  " .. (p.Text or p.Name or "Button"),
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.ButtonSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    })
    Create("UICorner", { Parent = btn, CornerRadius = udim(0, Config.Borders.ButtonRadius) })
    Create("UIStroke", { Parent = btn, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    btn.MouseEnter:Connect(function() Tween(btn, { BackgroundColor3 = rgb(Config.Colors.Hover) }, 0.1) end)
    btn.MouseLeave:Connect(function() Tween(btn, { BackgroundColor3 = rgb(Config.Colors.Element) }, 0.1) end)
    btn.MouseButton1Click:Connect(function() if p.Callback then p.Callback() end end)
    return btn
end

function ElementBuilder:Toggle(p)
    local state = p.Default or false
    local container = Create("Frame", { Parent = p.Parent, Size = udim2(1, 0, 0, Config.Sizes.ButtonHeight), BackgroundTransparency = 1 })
    local btn = Create("TextButton", {
        Parent = container,
        Size = udim2(1, 0, 1, 0),
        BackgroundColor3 = rgb(Config.Colors.Element),
        Text = "  " .. (p.Text or p.Name or "Toggle"),
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.ButtonSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    })
    Create("UICorner", { Parent = btn, CornerRadius = udim(0, Config.Borders.ButtonRadius) })
    Create("UIStroke", { Parent = btn, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    local indicator = Create("Frame", {
        Parent = btn,
        Size = udim2(0, 18, 0, 18),
        Position = udim2(1, -28, 0.5, -9),
        BackgroundColor3 = state and rgb(Config.Colors.Accent) or rgb(Config.Colors.Background),
    })
    Create("UICorner", { Parent = indicator, CornerRadius = udim(0, Config.Borders.ToggleRadius) })
    Create("UIStroke", { Parent = indicator, Color = rgb(Config.Colors.Outline), Thickness = 1 })
    local function SetState(newState)
        state = newState
        Tween(indicator, { BackgroundColor3 = state and rgb(Config.Colors.Accent) or rgb(Config.Colors.Background) }, 0.15)
        if p.Callback then p.Callback(state) end
    end
    btn.MouseButton1Click:Connect(function() SetState(not state) end)
    return { SetState = SetState, GetState = function() return state end }
end

function ElementBuilder:Slider(p)
    local min, max, default = p.Min or 0, p.Max or 100, p.Default or 50
    local decimals = p.Decimals or 1
    local container = Create("Frame", { Parent = p.Parent, Size = udim2(1, 0, 0, 55), BackgroundTransparency = 1 })
    local bg = Create("Frame", { Parent = container, Size = udim2(1, 0, 1, 0), BackgroundColor3 = rgb(Config.Colors.Element) })
    Create("UICorner", { Parent = bg, CornerRadius = udim(0, Config.Borders.ElementRadius) })
    Create("UIStroke", { Parent = bg, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    local label = Create("TextLabel", {
        Parent = bg,
        Size = udim2(1, 0, 0, 25),
        Position = udim2(0, 8, 0, 0),
        BackgroundTransparency = 1,
        Text = "  " .. (p.Text or "Slider"),
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.LabelSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    local valueLabel = Create("TextLabel", {
        Parent = bg,
        Size = udim2(0, 50, 0, 25),
        Position = udim2(1, -58, 0, 0),
        BackgroundTransparency = 1,
        Text = string.format("%." .. decimals .. "f", default),
        TextColor3 = rgb(Config.Colors.Accent),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.ValueSize,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    local barBg = Create("Frame", {
        Parent = bg,
        Size = udim2(1, -16, 0, 5),
        Position = udim2(0, 8, 0, 38),
        BackgroundColor3 = rgb(Config.Colors.Background),
    })
    Create("UICorner", { Parent = barBg, CornerRadius = udim(1, 0) })
    local fill = Create("Frame", {
        Parent = barBg,
        Size = udim2((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = rgb(Config.Colors.Accent),
    })
    Create("UICorner", { Parent = fill, CornerRadius = udim(1, 0) })
    local dragging = false
    local function UpdateValue(x)
        local pct = math.clamp((x - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * pct
        fill.Size = udim2(pct, 0, 1, 0)
        valueLabel.Text = string.format("%." .. decimals .. "f", val)
        if p.Callback then p.Callback(val) end
    end
    barBg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            UpdateValue(i.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateValue(i.Position.X)
        end
    end)
    return { SetValue = function(v) v = math.clamp(v, min, max); UpdateValue(barBg.AbsolutePosition.X + (v - min) / (max - min) * barBg.AbsoluteSize.X) end }
end

function ElementBuilder:Keybind(p)
    local key = p.Default or Enum.KeyCode.Unknown
    local btn = Create("TextButton", {
        Parent = p.Parent,
        Size = udim2(1, 0, 0, Config.Sizes.ButtonHeight),
        BackgroundColor3 = rgb(Config.Colors.Element),
        Text = "  " .. (p.Text or "Keybind") .. " : [" .. key.Name .. "]",
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.ButtonSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    })
    Create("UICorner", { Parent = btn, CornerRadius = udim(0, Config.Borders.ButtonRadius) })
    Create("UIStroke", { Parent = btn, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    local picking = false
    btn.MouseButton1Click:Connect(function()
        picking = true
        btn.Text = "  " .. (p.Text or "Keybind") .. " : [...]"
    end)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if picking and not gpe and input.UserInputType == Enum.UserInputType.Keyboard then
            picking = false
            key = input.KeyCode
            btn.Text = "  " .. (p.Text or "Keybind") .. " : [" .. key.Name .. "]"
            if p.Callback then p.Callback(key) end
        end
    end)
    return btn
end

function ElementBuilder:Dropdown(p)
    local items = p.Items or {}
    local selected = p.Default or items[1] or "None"
    local open = false
    local container = Create("Frame", { Parent = p.Parent, Size = udim2(1, 0, 0, Config.Sizes.ButtonHeight), BackgroundTransparency = 1 })
    local btn = Create("TextButton", {
        Parent = container,
        Size = udim2(1, 0, 1, 0),
        BackgroundColor3 = rgb(Config.Colors.Element),
        Text = "  " .. (p.Text or "Dropdown") .. " : " .. selected,
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.ButtonSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    })
    Create("UICorner", { Parent = btn, CornerRadius = udim(0, Config.Borders.ButtonRadius) })
    Create("UIStroke", { Parent = btn, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    local dropdown = Create("Frame", {
        Parent = container,
        Size = udim2(1, 0, 0, #items * 28),
        Position = udim2(0, 0, 1, 4),
        BackgroundColor3 = rgb(Config.Colors.Element),
        Visible = false,
        AutomaticSize = Enum.AutomaticSize.Y,
    })
    Create("UICorner", { Parent = dropdown, CornerRadius = udim(0, Config.Borders.DropdownRadius) })
    Create("UIStroke", { Parent = dropdown, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
    Create("UIListLayout", { Parent = dropdown, Padding = udim(0, 2) })
    for _, item in pairs(items) do
        local itemBtn = Create("TextButton", {
            Parent = dropdown,
            Size = udim2(1, 0, 0, 26),
            BackgroundColor3 = rgb(Config.Colors.Hover),
            Text = "  " .. item,
            TextColor3 = rgb(Config.Colors.Muted),
            FontFace = Font.new(Config.Fonts.Family),
            TextSize = Config.Fonts.LabelSize,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
        })
        itemBtn.MouseButton1Click:Connect(function()
            selected = item
            btn.Text = "  " .. (p.Text or "Dropdown") .. " : " .. selected
            dropdown.Visible = false
            open = false
            if p.Callback then p.Callback(selected) end
        end)
    end
    btn.MouseButton1Click:Connect(function()
        open = not open
        dropdown.Visible = open
    end)
    return { SetItems = function() end, GetValue = function() return selected end }
end

local function BuildWindow(props)
    local uiParent = getUIParent()
    if uiParent:FindFirstChild("NebulaUI") then uiParent.NebulaUI:Destroy() end
    local screen = Create("ScreenGui", { Parent = uiParent, Name = "NebulaUI", ResetOnSpawn = false })
    local main = Create("Frame", {
        Parent = screen,
        Size = udim2(0, Config.Window.Size.X, 0, Config.Window.Size.Y),
        Position = udim2(Config.Window.Position.X, -Config.Window.Size.X/2, Config.Window.Position.Y, -Config.Window.Size.Y/2),
        BackgroundColor3 = rgb(Config.Colors.Background),
        BackgroundTransparency = Config.Colors.Background.A,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    })
    Create("UICorner", { Parent = main, CornerRadius = udim(0, Config.Borders.WindowRadius) })
    Create("UIStroke", { Parent = main, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness, Transparency = Config.Borders.OutlineTransparency })
    local topbar = Create("Frame", {
        Parent = main,
        Size = udim2(1, 0, 0, Config.Sizes.TopbarHeight),
        BackgroundColor3 = rgb(Config.Colors.Topbar),
        BackgroundTransparency = Config.Colors.Topbar.A,
        BorderSizePixel = 0,
    })
    Create("UICorner", { Parent = topbar, CornerRadius = udim(0, Config.Borders.WindowRadius) })
    Create("Frame", { Parent = topbar, Size = udim2(1, 0, 1, 0), Position = udim2(0, 0, 1, -Config.Borders.WindowRadius), BackgroundColor3 = rgb(Config.Colors.Topbar), BackgroundTransparency = Config.Colors.Topbar.A, BorderSizePixel = 0 })
    local title = Create("TextLabel", {
        Parent = topbar,
        Size = udim2(1, -100, 1, 0),
        Position = udim2(0, 45, 0, 0),
        BackgroundTransparency = 1,
        Text = props.Name or "Nebula",
        TextColor3 = rgb(Config.Colors.Text),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = Config.Fonts.TitleSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    local closeBtn = Create("TextButton", {
        Parent = topbar,
        Size = udim2(0, 30, 0, 30),
        Position = udim2(1, -35, 0.5, -15),
        BackgroundTransparency = 1,
        Text = "✕",
        TextColor3 = rgb(Config.Colors.Muted),
        FontFace = Font.new(Config.Fonts.Family),
        TextSize = 18,
    })
    closeBtn.MouseButton1Click:Connect(function() screen:Destroy() end)
    if Config.Window.Resizable then
        local resize = Create("TextButton", {
            Parent = main,
            Size = udim2(0, 20, 0, 20),
            Position = udim2(1, -20, 1, -20),
            BackgroundTransparency = 1,
            Text = "↘",
            TextColor3 = rgb(Config.Colors.Muted),
            TextSize = 14,
        })
        local resizing, startPos, startSize
        resize.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true
                startPos = i.Position
                startSize = main.Size
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if resizing and i.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = i.Position - startPos
                local newX = math.clamp(startSize.X.Offset + delta.X, Config.Window.MinSize.X, Config.Window.MaxSize.X)
                local newY = math.clamp(startSize.Y.Offset + delta.Y, Config.Window.MinSize.Y, Config.Window.MaxSize.Y)
                main.Size = udim2(0, newX, 0, newY)
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
        end)
    end
    local dragging, dragStart, startFramePos
    topbar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = i.Position
            startFramePos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            main.Position = udim2(startFramePos.X.Scale, startFramePos.X.Offset + delta.X, startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    local sidebar = Create("ScrollingFrame", {
        Parent = main,
        Size = udim2(0, Config.Sizes.SidebarWidth, 1, -Config.Sizes.TopbarHeight),
        Position = udim2(0, 0, 0, Config.Sizes.TopbarHeight),
        BackgroundColor3 = rgb(Config.Colors.Sidebar),
        BackgroundTransparency = Config.Colors.Sidebar.A,
        BorderSizePixel = 0,
        ScrollBarThickness = 0,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    })
    Create("UIListLayout", { Parent = sidebar, Padding = udim(0, 5), HorizontalAlignment = Enum.HorizontalAlignment.Center })
    Create("UIPadding", { Parent = sidebar, PaddingTop = udim(0, 10) })
    local pageHolder = Create("Frame", {
        Parent = main,
        Size = udim2(1, -Config.Sizes.SidebarWidth, 1, -Config.Sizes.TopbarHeight),
        Position = udim2(0, Config.Sizes.SidebarWidth, 0, Config.Sizes.TopbarHeight),
        BackgroundTransparency = 1,
    })
    local tabs = {}
    local function AddTab(tabProps)
        local btn = Create("TextButton", {
            Parent = sidebar,
            Size = udim2(1, -16, 0, Config.Sizes.TabHeight),
            BackgroundColor3 = rgb(Config.Colors.Background),
            Text = "  " .. (tabProps.Name or "Tab"),
            TextColor3 = rgb(Config.Colors.Muted),
            FontFace = Font.new(Config.Fonts.Family),
            TextSize = Config.Fonts.TabSize,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
        })
        Create("UICorner", { Parent = btn, CornerRadius = udim(0, Config.Borders.ElementRadius) })
        Create("UIStroke", { Parent = btn, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
        local page = Create("ScrollingFrame", {
            Parent = pageHolder,
            Size = udim2(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = #tabs == 0,
            ScrollBarThickness = 0,
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
        })
        Create("UIListLayout", { Parent = page, FillDirection = Enum.FillDirection.Horizontal, Padding = udim(0, 15) })
        Create("UIPadding", { Parent = page, PaddingLeft = udim(0, 15), PaddingRight = udim(0, 15), PaddingTop = udim(0, 15), PaddingBottom = udim(0, 15) })
        local leftCol = Create("Frame", { Parent = page, Size = udim2(0.5, -8, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y })
        Create("UIListLayout", { Parent = leftCol, Padding = udim(0, Config.Sizes.ElementSpacing) })
        local rightCol = Create("Frame", { Parent = page, Size = udim2(0.5, -8, 0, 0), Position = udim2(0.5, 8, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y })
        Create("UIListLayout", { Parent = rightCol, Padding = udim(0, Config.Sizes.ElementSpacing) })
        btn.MouseButton1Click:Connect(function()
            for _, t in pairs(tabs) do t.page.Visible = false; t.btn.BackgroundColor3 = rgb(Config.Colors.Background); t.btn.TextColor3 = rgb(Config.Colors.Muted) end
            page.Visible = true
            btn.BackgroundColor3 = rgb(Config.Colors.Element)
            btn.TextColor3 = rgb(Config.Colors.Text)
        end)
        table.insert(tabs, { btn = btn, page = page, left = leftCol, right = rightCol })
        local function AddSection(sectionProps)
            local col = sectionProps.Side == "right" and rightCol or leftCol
            local section = Create("Frame", {
                Parent = col,
                Size = udim2(1, 0, 0, 0),
                BackgroundColor3 = rgb(Config.Colors.Section),
                BackgroundTransparency = Config.Colors.Section.A,
                AutomaticSize = Enum.AutomaticSize.Y,
            })
            Create("UICorner", { Parent = section, CornerRadius = udim(0, Config.Borders.SectionRadius) })
            Create("UIStroke", { Parent = section, Color = rgb(Config.Colors.Outline), Thickness = Config.Borders.OutlineThickness })
            Create("UIListLayout", { Parent = section, Padding = udim(0, 8) })
            Create("UIPadding", { Parent = section, PaddingTop = udim(0, Config.Sizes.SectionPadding), PaddingBottom = udim(0, Config.Sizes.SectionPadding), PaddingLeft = udim(0, Config.Sizes.SectionPadding), PaddingRight = udim(0, Config.Sizes.SectionPadding) })
            local header = Create("TextLabel", {
                Parent = section,
                Size = udim2(1, 0, 0, 24),
                BackgroundTransparency = 1,
                Text = "  " .. (sectionProps.Name or "Section"),
                TextColor3 = rgb(Config.Colors.Accent),
                FontFace = Font.new(Config.Fonts.Family),
                TextSize = Config.Fonts.SectionSize,
                TextXAlignment = Enum.TextXAlignment.Left,
            })
            Create("Frame", { Parent = section, Size = udim2(1, 0, 0, 1), BackgroundColor3 = rgb(Config.Colors.Outline) })
            local elements = Create("Frame", { Parent = section, Size = udim2(1, 0, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y })
            Create("UIListLayout", { Parent = elements, Padding = udim(0, Config.Sizes.ElementSpacing) })
            return setmetatable({ elements = elements }, { __index = ElementBuilder })
        end
        return { Section = AddSection }
    end
    return { Tab = AddTab, Notify = Notify, Destroy = function() screen:Destroy() end }
end

return { Window = BuildWindow, Config = Config, Notify = Notify }
